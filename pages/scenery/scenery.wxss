.scenery-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  background:
    linear-gradient(180deg, rgba(246, 251, 255, 0.98), rgba(238, 245, 252, 0.98));
  padding-bottom: 130rpx; /* Leave space for custom tab bar */
}

/* 分类Tab栏样式 */
.tabs {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  background-color: rgba(255, 255, 255, 0.82);
  padding: 20rpx 18rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 16rpx 34rpx rgba(16, 42, 82, 0.08);
  backdrop-filter: blur(16px);
}

.subtabs {
  display: flex;
  gap: 10rpx;
  margin: 14rpx 20rpx 0;
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 14rpx 30rpx rgba(16, 42, 82, 0.06);
  backdrop-filter: blur(14px);
}

.tab {
  flex: 1;
  font-size: 28rpx;
  color: #72829a;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
  transition: all 0.25s ease;
  background: linear-gradient(180deg, rgba(242, 247, 252, 0.92), rgba(230, 239, 250, 0.88));
  text-align: center;
  border: 1rpx solid rgba(12, 140, 255, 0.08);
}

.tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #20d5ff, #0c8cff);
  box-shadow: 0 12rpx 28rpx rgba(12, 140, 255, 0.24);
  transform: translateY(-1rpx);
}

.subtab {
  flex: 1;
  padding: 12rpx 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  background: linear-gradient(180deg, rgba(242, 247, 252, 0.9), rgba(230, 239, 250, 0.84));
  border: 1rpx solid rgba(12, 140, 255, 0.06);
  transition: all 0.2s ease;
}

.subtab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #20d5ff, #0c8cff);
  box-shadow: 0 10rpx 22rpx rgba(12, 140, 255, 0.2);
  transform: translateY(-1rpx);
}

/* 照片网格布局 */
.gallery {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

/* 照片卡片样式 */
.photo-item {
  position: relative;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 34rpx rgba(16, 42, 82, 0.1);
  border: 1rpx solid rgba(12, 140, 255, 0.08);
  transition: all 0.2s ease;
}

.photo-item:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 10rpx 20rpx rgba(19, 35, 66, 0.06);
}

.photo-scan {
  position: absolute;
  left: 0;
  top: 14rpx;
  z-index: 2;
  width: 44%;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(32, 213, 255, 0.9), transparent);
  box-shadow: 0 0 18rpx rgba(12, 140, 255, 0.42);
  pointer-events: none;
}

.photo-item image {
  width: 100%;
  height: 304rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.photo-desc {
  padding: 18rpx 16rpx;
  font-size: 26rpx;
  color: #0d1e38;
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border-top: 1rpx solid rgba(12, 140, 255, 0.08);
  letter-spacing: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 251, 255, 0.96));
}
