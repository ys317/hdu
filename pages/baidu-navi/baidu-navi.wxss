.nav-page {
  min-height: 100vh;
  padding: 40rpx 28rpx;
  background: linear-gradient(180deg, #f6fbff, #eef5fc);
}

.nav-card {
  padding: 34rpx 30rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(12, 140, 255, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(16, 42, 82, 0.12);
}

.nav-kicker {
  margin-bottom: 10rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #0c8cff;
}

.nav-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.nav-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #4d5d77;
  line-height: 1.5;
}

.nav-meta {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  color: #5c6d84;
  line-height: 1.5;
}

.nav-meta text + text {
  margin-top: 8rpx;
}

.nav-status {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #0c8cff;
}

.nav-error {
  color: #d94f3d;
}

.retry-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #0c8cff, #20d5ff);
  color: #fff;
  border-radius: 18rpx;
}
