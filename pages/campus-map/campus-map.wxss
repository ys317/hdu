.map-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 24rpx 20rpx 170rpx;
  background:
    linear-gradient(180deg, rgba(246, 251, 255, 0.98), rgba(238, 245, 252, 0.98));
}

.map-header {
  position: relative;
  z-index: 1;
  padding: 0 4rpx 18rpx;
}

.map-kicker {
  margin-bottom: 12rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4d5d77;
  line-height: 1.55;
}

/* Plane Map styling */
.map-frame {
  position: relative;
  z-index: 1;
  min-height: 900rpx;
  border-radius: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(12, 140, 255, 0.14);
  box-shadow: 0 22rpx 48rpx rgba(16, 42, 82, 0.14), 0 0 34rpx rgba(12, 140, 255, 0.08);
}

.map-frame-scan {
  position: absolute;
  left: 0;
  top: 20rpx;
  z-index: 2;
  width: 48%;
  height: 3rpx;
  pointer-events: none;
}

.static-map {
  position: relative;
  z-index: 1;
  width: 100%;
  display: block;
  background: #eef5fc;
}

.map-tips {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #20d5ff, #0c8cff);
  box-shadow: 0 0 14rpx rgba(12, 140, 255, 0.3);
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #40516b;
  line-height: 1.5;
}

.nav-section {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 22rpx 24rpx 18rpx;
  border-radius: 24rpx;
}

.nav-section-title {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4d5d77;
  line-height: 1.5;
}

.nav-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.nav-btn {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 124rpx;
  padding: 18rpx 18rpx 18rpx 20rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(12, 140, 255, 0.1), rgba(32, 213, 255, 0.06)),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 250, 255, 0.92));
  border: 1rpx solid rgba(12, 140, 255, 0.12);
  box-shadow: 0 14rpx 28rpx rgba(16, 42, 82, 0.08);
  text-align: left;
  overflow: hidden;
}

.nav-btn::after {
  content: '';
  position: absolute;
  right: -18rpx;
  top: -18rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(32, 213, 255, 0.22), transparent 72%);
  pointer-events: none;
}

.nav-btn::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(32, 213, 255, 0), rgba(32, 213, 255, 0.9), rgba(12, 140, 255, 0.9), rgba(32, 213, 255, 0));
  opacity: 0.72;
  pointer-events: none;
}

.nav-btn::after,
.nav-btn::before {
  pointer-events: none;
}

.nav-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

.nav-btn-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.nav-btn-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4d5d77;
  line-height: 1.4;
}

/* ============================================================
   Electronic Interactive Map Styles
   ============================================================ */

/* Switch Segmented Tabs */
.segment-tabs {
  display: flex;
  margin-top: 18rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(12, 140, 255, 0.12);
  box-shadow: 0 12rpx 30rpx rgba(16, 42, 82, 0.06);
}

.segment-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #586982;
  border-radius: 999rpx;
  transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}

.segment-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #0c8cff, #20d5ff);
  box-shadow: 0 6rpx 20rpx rgba(12, 140, 255, 0.28);
}

/* Map page container height control */
.interactive-map-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  height: calc(100vh - 290rpx);
  margin-top: 18rpx;
  border-radius: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(12, 140, 255, 0.14);
  box-shadow: 0 22rpx 48rpx rgba(16, 42, 82, 0.14), 0 0 34rpx rgba(12, 140, 255, 0.08);
}

/* Search bar styles */
.search-bar {
  display: flex;
  align-items: center;
  margin: 18rpx 18rpx 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(248, 251, 255, 0.9);
  border: 1rpx solid rgba(12, 140, 255, 0.12);
  box-shadow: inset 0 2rpx 8rpx rgba(12, 140, 255, 0.04);
}

.search-icon {
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #0b1b36;
  height: 36rpx;
  line-height: 36rpx;
}

.clear-icon {
  padding: 6rpx;
  flex-shrink: 0;
}

/* Category Filter Capsules Scrollable */
.category-scroll {
  display: flex;
  white-space: nowrap;
  padding: 0 18rpx 14rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.category-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5c6c84;
  border-radius: 999rpx;
  background: rgba(12, 140, 255, 0.06);
  border: 1rpx solid rgba(12, 140, 255, 0.08);
  transition: all 0.22s ease;
}

.category-badge.active {
  color: #0c8cff;
  background: rgba(12, 140, 255, 0.14);
  border-color: rgba(12, 140, 255, 0.3);
  box-shadow: 0 4rpx 14rpx rgba(12, 140, 255, 0.08);
  font-weight: 700;
}

/* Live Map Box and Native Component */
.map-box {
  flex: 1;
  position: relative;
  width: 100%;
  height: 100%;
}

.native-map {
  width: 100%;
  height: 100%;
}

/* Geolocation floating pan button */
.locate-btn {
  position: absolute;
  right: 24rpx;
  bottom: 40rpx;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid rgba(12, 140, 255, 0.2);
  box-shadow: 0 10rpx 24rpx rgba(16, 42, 82, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.locate-icon {
  width: 44rpx;
  height: 44rpx;
}

/* Sliding details drawer card */
.detail-drawer {
  position: absolute;
  bottom: 18rpx;
  left: 18rpx;
  right: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(12, 140, 255, 0.18);
  box-shadow: 0 16rpx 48rpx rgba(16, 42, 82, 0.24);
  backdrop-filter: blur(18px);
  z-index: 100;
  transform: translateY(120%);
  transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
}

.detail-drawer.show {
  transform: translateY(0);
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.drawer-title-box {
  display: flex;
  flex-direction: column;
}

.drawer-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0b1b36;
}

.drawer-tag {
  align-self: flex-start;
  margin-top: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(12, 140, 255, 0.12), rgba(32, 213, 255, 0.08));
  border: 1rpx solid rgba(12, 140, 255, 0.14);
  color: #0d4fa2;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.drawer-close-btn {
  font-size: 44rpx;
  color: #72829a;
  padding: 4rpx 12rpx;
  line-height: 0.8;
}

.drawer-close-btn:active {
  opacity: 0.6;
}

.drawer-body {
  margin-bottom: 0;
}

.drawer-desc {
  font-size: 25rpx;
  color: #43536a;
  line-height: 1.6;
  display: block;
}

.drawer-distance-box {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(32, 213, 255, 0.08);
  border: 1rpx solid rgba(32, 213, 255, 0.12);
}

.distance-pulse {
  width: 10rpx;
  height: 10rpx;
  background: #20d5ff;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 10rpx rgba(32, 213, 255, 0.8);
}

.distance-label {
  font-size: 22rpx;
  color: #43536a;
}

.distance-value {
  font-size: 22rpx;
  font-weight: 700;
  color: #0c8cff;
}
