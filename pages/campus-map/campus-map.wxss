.map-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 24rpx 20rpx 170rpx;
  background:
    linear-gradient(180deg, rgba(246, 251, 255, 0.98), rgba(238, 245, 252, 0.98));
}

.map-header {
  position: relative;
  z-index: 1;
  padding: 0 4rpx 18rpx;
}

.map-kicker {
  margin-bottom: 12rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4d5d77;
  line-height: 1.55;
}

.map-frame {
  position: relative;
  z-index: 1;
  min-height: 900rpx;
  border-radius: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(12, 140, 255, 0.14);
  box-shadow: 0 22rpx 48rpx rgba(16, 42, 82, 0.14), 0 0 34rpx rgba(12, 140, 255, 0.08);
}

.map-frame-scan {
  position: absolute;
  left: 0;
  top: 20rpx;
  z-index: 2;
  width: 48%;
  height: 3rpx;
  pointer-events: none;
}

.static-map {
  position: relative;
  z-index: 1;
  width: 100%;
  display: block;
  background: #eef5fc;
}

.map-tips {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #20d5ff, #0c8cff);
  box-shadow: 0 0 14rpx rgba(12, 140, 255, 0.3);
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #40516b;
  line-height: 1.5;
}

.nav-section {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 22rpx 24rpx 18rpx;
  border-radius: 24rpx;
}

.nav-section-title {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4d5d77;
  line-height: 1.5;
}

.nav-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.nav-btn {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 124rpx;
  padding: 18rpx 18rpx 18rpx 20rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(12, 140, 255, 0.1), rgba(32, 213, 255, 0.06)),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 250, 255, 0.92));
  border: 1rpx solid rgba(12, 140, 255, 0.12);
  box-shadow: 0 14rpx 28rpx rgba(16, 42, 82, 0.08);
  text-align: left;
  overflow: hidden;
}

.nav-btn::after {
  content: '';
  position: absolute;
  right: -18rpx;
  top: -18rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(32, 213, 255, 0.22), transparent 72%);
  pointer-events: none;
}

.nav-btn::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(32, 213, 255, 0), rgba(32, 213, 255, 0.9), rgba(12, 140, 255, 0.9), rgba(32, 213, 255, 0));
  opacity: 0.72;
  pointer-events: none;
}

.nav-btn::after,
.nav-btn::before {
  pointer-events: none;
}

.nav-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

.nav-btn-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0b1b36;
  line-height: 1.3;
}

.nav-btn-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4d5d77;
  line-height: 1.4;
}
