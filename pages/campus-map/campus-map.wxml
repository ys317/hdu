<view class="map-container tech-shell">
  <view class="tech-grid-overlay"></view>

  <view class="map-header tech-rise">
    <view class="map-kicker tech-chip">STATIC CAMPUS MAP</view>
    <text class="page-title">杭电校园地图</text>
    <text class="page-subtitle">校园平面导览图已作为本地静态资源加载，点击地图可全屏查看</text>
  </view>

  <view class="map-frame tech-panel tech-rise" style="animation-delay: 120ms;" bindtap="previewMap">
    <view class="map-frame-scan tech-sweep"></view>
    <image class="static-map" src="{{mapImage}}" mode="widthFix" />
  </view>

  <view class="map-tips tech-panel tech-rise" style="animation-delay: 220ms;">
    <view class="tip-item">
      <text class="tip-dot"></text>
      <text class="tip-text">地图已随小程序页面自动加载，无需等待定位服务</text>
    </view>
    <view class="tip-item">
      <text class="tip-dot"></text>
      <text class="tip-text">点击地图后可双指缩放查看细节</text>
    </view>
  </view>

  <view class="nav-section tech-rise" style="animation-delay: 300ms;">
    <view class="nav-section-title">
      <text class="section-title">地图导航</text>
      <text class="section-subtitle">点击建筑按钮，打开目标地点</text>
    </view>

    <view class="nav-grid">
      <button
        wx:for="{{navTargets}}"
        wx:for-item="item"
        wx:for-index="index"
        wx:key="id"
        class="nav-btn tech-rise"
        plain="true"
        style="animation-delay: {{index * 70}}ms;"
        bindtap="goToBaiduNavigation"
        data-name="{{item.name}}"
        data-nav-name="{{item.navName}}"
        data-desc="{{item.desc}}"
        data-lat="{{item.lat}}"
        data-lng="{{item.lng}}"
      >
        <view class="nav-btn-name">{{item.name}}</view>
        <view class="nav-btn-desc">{{item.desc}}</view>
      </button>
    </view>
  </view>
</view>
