.detail-container {
  min-height: 100vh;
  background-color: #ffffff;
  padding-bottom: 60rpx;
}

.cover-image {
  width: 100%;
  height: 420rpx;
  display: block;
}

.article-body {
  padding: 40rpx 30rpx;
}

.title {
  font-size: 38rpx;
  font-weight: bold;
  color: #1e3a8a;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.meta-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.divider {
  margin: 0 16rpx;
  color: #dddddd;
}

.content-paragraphs {
  margin-top: 10rpx;
}

.paragraph {
  margin-bottom: 32rpx;
  text-indent: 56rpx; /* 首行缩进 */
}

.para-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  text-align: justify;
  display: block;
}

.footer-btn {
  margin: 60rpx 40rpx 100rpx 40rpx;
}

.back-btn {
  background-color: #1e3a8a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(30, 58, 138, 0.2);
}

.back-btn:active {
  opacity: 0.9;
}