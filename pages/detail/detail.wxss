.detail-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  background:
    linear-gradient(180deg, rgba(246, 251, 255, 0.98), rgba(238, 245, 252, 0.98));
  padding-bottom: 80rpx;
}

.cover-frame {
  position: relative;
  width: calc(100% - 40rpx);
  margin: 20rpx 20rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(16, 42, 82, 0.14), 0 0 28rpx rgba(12, 140, 255, 0.06);
  border: 1rpx solid rgba(12, 140, 255, 0.14);
}

.cover-image {
  width: 100%;
  height: 460rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.cover-grid {
  position: absolute;
  inset: 0;
  z-index: 2;
  background-image:
    linear-gradient(135deg, rgba(32, 213, 255, 0.1), transparent 46%),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.16) 0, rgba(255, 255, 255, 0.16) 1rpx, transparent 1rpx, transparent 56rpx);
  opacity: 0.38;
  pointer-events: none;
}

.cover-scan {
  position: absolute;
  left: 0;
  top: 18rpx;
  z-index: 3;
  width: 48%;
  height: 3rpx;
  pointer-events: none;
}

.article-body {
  margin: -28rpx 20rpx 0;
  padding: 36rpx 28rpx 34rpx;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 38rpx rgba(19, 35, 66, 0.08);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.body-accent {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  pointer-events: none;
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #0b1b36;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.meta-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.meta-pill {
  display: inline-block;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #0c6bc4;
  background: rgba(12, 140, 255, 0.08);
  border-radius: 999rpx;
  border: 1rpx solid rgba(12, 140, 255, 0.1);
}

.content-paragraphs {
  margin-top: 10rpx;
}

.paragraph {
  margin-bottom: 28rpx;
  text-indent: 56rpx; /* 首行缩进 */
}

.para-text {
  font-size: 28rpx;
  color: #23324a;
  line-height: 1.9;
  text-align: justify;
  display: block;
}

.footer-btn {
  margin: 34rpx 20rpx 100rpx;
}

.back-btn {
  width: 100%;
  background: linear-gradient(135deg, #20d5ff, #0c8cff);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 16rpx 28rpx rgba(12, 140, 255, 0.2);
}

.back-btn:active {
  opacity: 0.92;
}
