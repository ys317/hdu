.history-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 160rpx; /* Leave space for custom tab bar */
}

/* 顶部 Banner 区 */
.header {
  position: relative;
  height: 380rpx;
  width: 100%;
  overflow: hidden;
}

.header-bg {
  width: 100%;
  height: 100%;
  display: block;
}

.header-text {
  position: absolute;
  left: 40rpx;
  bottom: 40rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
}

.big-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.5);
}

.sub-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 10rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.5);
}

/* 时间线布局 */
.timeline {
  padding: 40rpx 24rpx;
  box-sizing: border-box;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 48rpx;
}

/* 时间线连接线 */
.timeline-item::after {
  content: '';
  position: absolute;
  left: 164rpx; /* 精确计算的中心线位置：120rpx(year) + 30rpx(margin) + 16rpx(dot中心) - 2rpx(线宽的一半) */
  top: 36rpx;
  bottom: 0;
  width: 4rpx;
  background-color: #e2e8f0;
  z-index: 1;
}

.timeline-item:last-child::after {
  display: none; /* 最后一项不显示连接线 */
}

/* 年份样式 */
.year {
  width: 120rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #1e3a8a;
  text-align: right;
  margin-right: 30rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

/* 圆点样式 */
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  border: 6rpx solid #ffffff;
  box-shadow: 0 0 0 6rpx rgba(30, 58, 138, 0.1);
  z-index: 5;
  margin-top: 14rpx;
  flex-shrink: 0;
}

/* 卡片内容样式 */
.content {
  flex: 1;
  margin-left: 30rpx;
  background-color: #ffffff;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(30, 58, 138, 0.02);
  border: 1rpx solid #f1f5f9;
  z-index: 5;
  transform: translate3d(0, 0, 0);
  transition: all 0.2s ease;
}

.timeline-item:active .content {
  background-color: #f8fafc;
  transform: translateY(2rpx);
}

.event-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e3a8a;
  margin-bottom: 8rpx;
  display: block;
}

.event-desc {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.5;
  display: block;
}