.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 118rpx;
  background: rgba(248, 251, 255, 0.9);
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -18rpx 38rpx rgba(16, 42, 82, 0.1);
  border-top: 1rpx solid rgba(19, 124, 255, 0.1);
  padding-bottom: calc(env(safe-area-inset-bottom) + 8rpx);
  z-index: 999;
  backdrop-filter: blur(18px);
}

.tab-bar-line {
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(32, 213, 255, 0.92), rgba(12, 140, 255, 0.92), transparent);
  box-shadow: 0 0 18rpx rgba(12, 140, 255, 0.35);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  transition: all 0.24s ease;
  -webkit-tap-highlight-color: transparent;
  outline: none;
}

.tab-item.selected {
  transform: translateY(-3rpx);
}

.icon-shell {
  position: relative;
  width: 68rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  border: 1rpx solid transparent;
  transition: all 0.24s ease;
}

.tab-item.selected .icon-shell {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}



.icon {
  position: relative;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.tab-item.selected .icon {
  transform: scale(1.16);
}

.text {
  font-size: 22rpx;
  color: #72829a;
  margin-top: 2rpx;
}

.text.active {
  color: #0c8cff;
  font-weight: 700;
}

.tab-item:active {
  opacity: 0.6;
}
