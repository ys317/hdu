.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.08);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.icon {
  width: 48rpx;
  height: 48rpx;
}

.text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.text.active {
  color: #1e3a8a;
  font-weight: bold;
}

.tab-item:active {
  opacity: 0.6;
}
